# Security Configuration for Solan Web Interface
# Copy this to your .env file and customize

# Environment
ENVIRONMENT=development
# ENVIRONMENT=production

# Server Configuration
HOST=127.0.0.1
PORT=8000
USE_HTTPS=false

# API Security
SOLAN_API_KEY=your_secure_api_key_here_generate_a_strong_one

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Trusted Hosts (comma-separated)
TRUSTED_HOSTS=localhost,127.0.0.1,yourdomain.com

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# SSL/TLS (for HTTPS)
SSL_CERT_FILE=certs/cert.pem
SSL_KEY_FILE=certs/key.pem

# Logging
SECURITY_LOG_LEVEL=INFO
SECURITY_LOG_FILE=logs/security.log
