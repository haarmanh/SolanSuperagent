# 🛡️ SOLAN SECURITY ENVIRONMENT VARIABLES
# =====================================
# 
# ⚠️ CRITICAL SECURITY NOTICE:
# - NEVER commit actual values to git
# - Use GitHub Secrets for production
# - Rotate all secrets regularly
# - Use strong, unique passwords

# 🔐 API SECURITY
SOLAN_API_SECRET_KEY=your_super_secure_api_key_here
SOLAN_JWT_SECRET=your_jwt_signing_secret_here
SOLAN_ENCRYPTION_KEY=your_32_character_encryption_key

# 🌐 DEPLOYMENT SECRETS (GitHub Secrets Only)
VERCEL_TOKEN=your_vercel_deployment_token
VERCEL_ORG_ID=your_vercel_org_id
VERCEL_PROJECT_ID=your_vercel_project_id

# 🖥️ HETZNER SECURITY (GitHub Secrets Only)
HETZNER_SSH_PRIVATE_KEY=your_ssh_private_key
HETZNER_SERVER_IP=95.216.209.234
HETZNER_API_TOKEN=your_hetzner_api_token

# 🗄️ DATABASE SECURITY
DATABASE_URL=your_encrypted_database_url
DATABASE_ENCRYPTION_PASSWORD=your_db_encryption_password
REDIS_URL=your_redis_connection_string
REDIS_PASSWORD=your_redis_password

# 🔒 SSL/TLS CERTIFICATES
SSL_CERTIFICATE_PASSWORD=your_ssl_cert_password
SSL_PRIVATE_KEY_PATH=/path/to/private/key
SSL_CERTIFICATE_PATH=/path/to/certificate

# 🚨 MONITORING & ALERTS
SECURITY_WEBHOOK_URL=your_security_alert_webhook
MONITORING_API_KEY=your_monitoring_service_key
LOG_ENCRYPTION_KEY=your_log_encryption_key

# 🛡️ RATE LIMITING
RATE_LIMIT_SECRET=your_rate_limit_secret
RATE_LIMIT_REDIS_URL=your_rate_limit_redis_url

# 🔐 BACKUP SECURITY
BACKUP_ENCRYPTION_PASSWORD=your_backup_encryption_password
BACKUP_S3_ACCESS_KEY=your_s3_access_key
BACKUP_S3_SECRET_KEY=your_s3_secret_key

# 🌍 ENVIRONMENT CONFIGURATION
NODE_ENV=production
SECURITY_LEVEL=maximum
THREAT_DETECTION=enabled
AUTO_ROLLBACK=enabled

# 🔍 AUDIT & COMPLIANCE
AUDIT_LOG_ENCRYPTION=enabled
COMPLIANCE_MODE=gdpr
DATA_RETENTION_DAYS=90

# ⚡ PERFORMANCE SECURITY
CDN_SECURITY_TOKEN=your_cdn_security_token
CACHE_ENCRYPTION_KEY=your_cache_encryption_key

# 🚨 EMERGENCY CONTACTS
SECURITY_ADMIN_EMAIL=security@solanai.ai
EMERGENCY_CONTACT=emergency@solanai.ai
INCIDENT_WEBHOOK=your_incident_response_webhook

# 🔐 MULTI-FACTOR AUTHENTICATION
MFA_SECRET_KEY=your_mfa_secret_key
TOTP_ISSUER=SolanAI
BACKUP_CODES_ENCRYPTION=your_backup_codes_key

# 🛡️ SECURITY HEADERS
SECURITY_HEADERS_ENABLED=true
HSTS_MAX_AGE=31536000
CSP_REPORT_URI=https://your-csp-report-endpoint

# 🚨 INTRUSION DETECTION
IDS_API_KEY=your_intrusion_detection_key
THREAT_INTEL_API=your_threat_intelligence_api
SECURITY_SCAN_TOKEN=your_security_scan_token

# 📊 SECURITY METRICS
METRICS_ENCRYPTION_KEY=your_metrics_encryption_key
ANALYTICS_SECURITY_TOKEN=your_analytics_token

# 🔒 ZERO-TRUST CONFIGURATION
ZERO_TRUST_ENABLED=true
DEVICE_TRUST_TOKEN=your_device_trust_token
NETWORK_POLICY_KEY=your_network_policy_key
